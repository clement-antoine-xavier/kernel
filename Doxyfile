PROJECT_NAME           = "Kernel"
PROJECT_NUMBER         = 1.0.0
PROJECT_BRIEF          = "An experimental kernel project using C++."
OUTPUT_DIRECTORY       = docs

# Input

INPUT                  = headers sources
FILE_PATTERNS          = *.hpp *.cpp
RECURSIVE              = YES

# Build configuration

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_ANON_NSPACES   = YES

# Documentation

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO

# Optimization

OPTIMIZE_OUTPUT_FOR_C  = NO
MARKDOWN_SUPPORT       = YES

# Warnings and messages

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_NO_PARAMDOC       = YES

# Layout

FULL_PATH_NAMES        = YES

# Code generation

INLINE_SOURCES         = YES
SOURCE_BROWSER         = YES
VERBATIM_HEADERS       = YES
